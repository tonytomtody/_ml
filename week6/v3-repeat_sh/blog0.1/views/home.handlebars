<h2>最新文章</h2>

{{#if posts}}
  {{#each posts}}
    <article class="post">
      <h2><a href="/post/{{slug}}">{{title}}</a></h2>
      <p class="meta">發布日期: {{formatDate createdAt}}</p>
      <div class="content">
        {{#if (truncate content 200)}}
          {{truncate content 200}}
          <a href="/post/{{slug}}">閱讀更多...</a>
        {{/if}}
      </div>
    </article>
  {{/each}}
{{else}}
  <p>尚無文章，請前往<a href="/admin">管理後台</a>發布第一篇文章！</p>
{{/if}}
